  "metadata": {
    "what_it_measures": "Chicago Fed National Activity Index 3-month moving average. Composite of 85 indicators. Designed so 0 = historical average growth, negative = below-average growth.\n",
    "why_it_matters": "Value below -0.7 historically = recession risk rising. Below -1.5 = recession likely underway. Above +0.7 = above-trend growth, watch for inflation. Baumohl considers this the broadest single activity gauge.\n",
    "scoring_rule": "> +1.0 \u2192 -30 (overheating, late-cycle warning) +0.7 to +1.0 \u2192 0 (inflation acceleration risk) +0.2 to +0.7 \u2192 +60 (healthy expansion) -0.7 to +0.2 \u2192 +20 (neutral/slowing) -1.5 to -0.7 \u2192 -60 (recession risk rising) < -1.5 \u2192 -100 (recession underway)\n"
  },
